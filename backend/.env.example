# Copia este archivo a ".env" y ajusta los valores antes de desplegar a producción.
# En desarrollo local, si no se define nada, el backend usa valores por
# defecto seguros solo para desarrollo (ver auth_utils.py).

# Seguridad
SECRET_KEY=cambia-esta-clave-en-produccion
ADMIN_CODE=codigo-secreto-para-admins
ALGORITHM=HS256
TOKEN_EXPIRE_DAYS=7

# Base de datos
DATABASE_URL=sqlite:///./veterinary.db

# CORS — lista de orígenes permitidos separados por coma.
# Sin definir, se permite cualquier origen (solo válido para desarrollo).
CORS_ORIGINS=http://localhost:4200,https://tu-dominio.com

# Notificaciones push (Web Push / VAPID) — ver push_utils.py.
# Sin definir, se usa un par de desarrollo ya generado (válido solo para
# local). En producción, genera un par propio y estable: si cambia, todas
# las suscripciones existentes en los navegadores de los usuarios dejan de
# funcionar y deben volver a activarlas.
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); ..."
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_PEM=
VAPID_CLAIMS_EMAIL=mailto:contacto@cityvet.pe
